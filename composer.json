{
    "name": "nextcloud/integration_pexip",
    "authors": [
        {
            "name": "Julien Veyssier",
            "email": "julien-nc@posteo.net"
        }
    ],
    "require": {
        "php": "^8.2",
        "bamarni/composer-bin-plugin": "^1.9"
    },
    "scripts": {
		"lint": "find . -name \\*.php -not -path './vendor/*' -print0 | xargs -0 -n1 php -l",
		"cs:check": "php-cs-fixer fix --dry-run --diff",
		"cs:fix": "php-cs-fixer fix",
		"psalm": "psalm --no-cache",
		"psalm:update-baseline": "psalm --threads=1 --update-baseline",
		"psalm:update-baseline:force": "psalm --threads=1 --update-baseline --set-baseline=tests/psalm-baseline.xml",
		"test:unit": "phpunit --config tests/phpunit.xml",
		"openapi": "generate-spec --verbose",
        "post-install-cmd": [
			"composer dump-autoload"
		],
		"post-update-cmd": [
			"composer dump-autoload"
		]
	},
	"require-dev": {
		"nextcloud/coding-standard": "^1.1",
		"nextcloud/ocp": "dev-master",
		"nextcloud/openapi-extractor": "^1.0.0",
		"phpunit/phpunit": "^11.5"
	},
	"config": {
		"sort-packages": true,
		"optimize-autoloader": true,
		"platform": {
			"php": "8.2"
		},
		"autoloader-suffix": "Pexip",
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true
        }
	},
    "extra": {
		"bamarni-bin": {
			"bin-links": true,
			"target-directory": "vendor-bin",
			"forward-command": true
		}
	}
}
